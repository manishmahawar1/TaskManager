<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Task Manager</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 flex justify-center px-3">

  <div class="w-full max-w-2xl mt-6 md:mt-10">

    <!-- Title -->
    <h1 class="text-2xl md:text-4xl font-semibold text-center text-gray-700 mb-6">
      Task Manager
    </h1>

    <hr class="mb-6">

    <!-- Add Task Form -->
    <form action="/add" method="POST" class="flex flex-col sm:flex-row gap-3 mb-6">
      <input 
        type="text" 
        name="title" 
        placeholder="Enter a new task..." 
        class="flex-1 p-3 border rounded-md outline-none"
        required
      />
      <button 
        class="bg-blue-500 text-white px-5 py-2 rounded-md hover:bg-blue-600 w-full sm:w-auto">
        Add Task
      </button>
    </form>

    <hr class="mb-6">

    <!-- Task List Title -->
    <h2 class="text-lg md:text-xl font-semibold text-gray-700 mb-4">
      Task List
    </h2>

    <!-- Task List -->
    <div class="bg-white rounded-md shadow overflow-hidden">

      <% if(tasks.length === 0){ %>
        <p class="p-4 text-gray-500 text-center">No tasks yet</p>
      <% } %>

      <% tasks.forEach(task => { %>

        <div class="flex flex-col sm:flex-row sm:items-center justify-between p-4 border-b gap-3">

          <!-- Left Section -->
          <div class="flex items-start gap-3">

            <!-- Checkbox -->
            <input 
              type="checkbox"
              <%= task.completed ? "checked" : "" %>
              onchange="window.location='/toggle/<%= task.id %>'"
              class="mt-1"
            />

            <!-- Task Info -->
            <div>
              <p class="text-base md:text-lg font-medium 
                <%= task.completed ? 'line-through text-gray-400' : 'text-gray-800' %>">
                <%= task.title %>
              </p>

              <p class="text-xs md:text-sm text-gray-500">
                Created: <%= task.createdAt %>
              </p>
            </div>

          </div>

          <!-- Delete Button -->
          <a 
            href="/delete/<%= task.id %>" 
            class="bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600 text-center w-full sm:w-auto">
            Delete
          </a>

        </div>

      <% }) %>

    </div>

  </div>

</body>
</html>